    "@angular/platform-browser": "19.2.23",
    "@angular/platform-browser-dynamic": "19.2.23",
    "@angular/router": "19.2.23",
    "express": "^4.21.2",
    "rxjs": "~7.8.1",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.23",
